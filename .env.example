APP_NAME=Reputation
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (Docker internal network)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=reputation
DB_USERNAME=reputation
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Ingest API
INGEST_API_TOKEN=
INGEST_IDEMPOTENCY_LOCK_TTL=300

# Claude / Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE=0
CLAUDE_INCLUDE_TEMPERATURE=false
CLAUDE_MAX_TOKENS=1024

# LLM Cascade (Haiku → Sonnet → Opus)
LLM_CASCADE_ENABLED=true
LLM_CASCADE_ESCALATION_ENABLED=true
LLM_CASCADE_HAIKU_MODEL=claude-haiku-4-5
LLM_CASCADE_SONNET_MODEL=claude-sonnet-4-6
LLM_CASCADE_OPUS_MODEL=claude-opus-4-8
LLM_CASCADE_FALLBACK_MODEL=claude-sonnet-4-6
LLM_CASCADE_FALLBACK_TIER=sonnet
LLM_CASCADE_HAIKU_MAX_TEXT_LENGTH=500
LLM_CASCADE_SONNET_MAX_TEXT_LENGTH=2000
LLM_CASCADE_HAIKU_MAX_CONFIDENCE=70
LLM_CASCADE_HAIKU_ESCALATE_SEVERITY_MIN=4
LLM_CASCADE_SONNET_MAX_CONFIDENCE=75
LLM_CASCADE_SONNET_ESCALATE_SEVERITY_MIN=5
LLM_COST_HAIKU_INPUT=0.00000025
LLM_COST_HAIKU_OUTPUT=0.00000125
LLM_COST_SONNET_INPUT=0.000003
LLM_COST_SONNET_OUTPUT=0.000015
LLM_COST_OPUS_INPUT=0.000015
LLM_COST_OPUS_OUTPUT=0.000075

# Structured Classification & Prompt Injection Protection
CLASSIFICATION_SEVERITY_MIN=1
CLASSIFICATION_SEVERITY_MAX=5
CLASSIFICATION_CONFIDENCE_MIN=0
CLASSIFICATION_CONFIDENCE_MAX=100
CLASSIFICATION_VALIDATION_MAX_RETRIES=1
CLASSIFICATION_VALIDATION_ESCALATE_ON_FAILURE=true
CLASSIFICATION_INJECTION_GUARD_ENABLED=true
CLASSIFICATION_TOOL_USE_ENABLED=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# Deprecated: single chat ID still supported for backward compatibility
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Telegram Delivery Bot (Phase 2 — separate from moderation)
TELEGRAM_DELIVERY_BOT_TOKEN=
TELEGRAM_DELIVERY_CHAT_IDS=

# Optional: override moderation bot separately from delivery
TELEGRAM_MODERATION_BOT_TOKEN=
TELEGRAM_MODERATION_CHAT_IDS=

# Brand24
BRAND24_API_KEY=
BRAND24_BASE_URL=https://api-data.brand24.com
BRAND24_ACCOUNT_ID=

# Mentionlytics (API v2 — polling; no webhooks)
MENTIONLYTICS_BEARER_TOKEN=
MENTIONLYTICS_REFRESH_TOKEN=
MENTIONLYTICS_BASE_URL=https://api.mentionlytics.com/v2
MENTIONLYTICS_POLL_PER_PAGE=20
MENTIONLYTICS_POLL_LOOKBACK_DAYS=7

# Deduplication (Fuzzy SimHash + Exact Fallback)
DEDUP_EXACT_FALLBACK_ENABLED=true
DEDUP_FUZZY_ENABLED=true
DEDUP_FUZZY_STRATEGY=App\\Services\\Deduplication\\SimHashMatchingStrategy
DEDUP_SIMILARITY_THRESHOLD=0.85
DEDUP_SIMILARITY_MINIMUM=0.70
DEDUP_WEIGHT_CONTENT=0.50
DEDUP_WEIGHT_TITLE=0.15
DEDUP_WEIGHT_URL=0.20
DEDUP_WEIGHT_AUTHOR=0.10
DEDUP_WEIGHT_PUBLISHED_AT=0.05
DEDUP_SIMHASH_BITS=64
DEDUP_SIMHASH_MAX_HAMMING_DISTANCE=8
DEDUP_MINHASH_PERMUTATIONS=128
DEDUP_TIME_WINDOW_HOURS=72

# Person Engine
PERSON_TYPO_VARIANTS_ENABLED=true
PERSON_TYPO_MAX_PER_ALIAS=10
PERSON_RESOLVER_AMBIGUITY_THRESHOLD=0.05
PERSON_TEST_RUSSIAN_NAME="Владимир Путин"
PERSON_TEST_ENGLISH_NAME="John Smith"
PERSON_TEST_RUSSIAN_ALIAS="Путин В.В."
PERSON_TEST_ENGLISH_ALIAS="J. Smith"

# SerpApi (SERP layer)
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com
SERPAPI_TEST_QUERY="reputation monitoring"
SERPAPI_TEST_ENGINE=google

# Routing Engine (Phase 2)
ROUTING_TIMEZONE=UTC

# Delivery & Digest Engine (Phase 2)
DELIVERY_DIGEST_MORNING_HOUR=8
DELIVERY_DIGEST_MORNING_MINUTE=0
DELIVERY_DIGEST_EVENING_HOUR=18
DELIVERY_DIGEST_EVENING_MINUTE=0
DELIVERY_DEFAULT_DIGEST_TYPE=morning
DELIVERY_DEFERRED_DIGEST_TYPE=evening

# Docker
NGINX_PORT=8080

# Uncomment to expose PostgreSQL to the host (not recommended for production)
# POSTGRES_PORT=5432
